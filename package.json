{
  "name": "@statewalker/ai-agent",
  "version": "0.0.0",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./agent": "./src/agent/index.ts",
    "./events": "./src/events/index.ts",
    "./tools": "./src/tools/index.ts",
    "./context": "./src/context/index.ts",
    "./skills": "./src/skills/index.ts"
  },
  "files": ["dist/**", "src/**"],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest run",
    "test:watch": "vitest",
